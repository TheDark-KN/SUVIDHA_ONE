# SUVIDHA ONE Frontend Environment Variables
# Copy this file to .env.local and update with your values

# Backend API URL (your Render deployment)
NEXT_PUBLIC_API_URL=https://suvidha-one.onrender.com

# Application settings
NEXT_PUBLIC_APP_NAME="SUVIDHA ONE"
NEXT_PUBLIC_APP_VERSION=1.0.0

# Kiosk settings
NEXT_PUBLIC_KIOSK_MODE=true
NEXT_PUBLIC_AUTO_FULLSCREEN=true
NEXT_PUBLIC_WAKE_LOCK=true

# Session timeout (in seconds)
NEXT_PUBLIC_SESSION_TIMEOUT=300

# OTP settings
NEXT_PUBLIC_OTP_LENGTH=6
NEXT_PUBLIC_OTP_EXPIRY=300
NEXT_PUBLIC_OTP_RESEND_COOLDOWN=60

# Feature flags
NEXT_PUBLIC_ENABLE_BILL_PAYMENT=true
NEXT_PUBLIC_ENABLE_CERTIFICATES=true
NEXT_PUBLIC_ENABLE_GRIEVANCES=true
NEXT_PUBLIC_ENABLE_FINGERPRINT=false
NEXT_PUBLIC_ENABLE_QR_SCAN=false

# Razorpay Configuration
# Get these from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_test_key_id_here
# NOTE: RAZORPAY_KEY_SECRET should ONLY be in backend .env, never in frontend!
# RAZORPAY_WEBHOOK_SECRET is configured in backend for webhook signature verification
