# SUVIDHA ONE Backend Environment Variables

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/suvidha

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration (RS256 Keys)
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# OTP Configuration
OTP_HMAC_SECRET=

# UIDAI (Aadhaar)
UIDAI_API_KEY=
UIDAI_AUA_CODE=

# NPCI (Payments)
NPCI_MERCHANT_ID=
NPCI_WEBHOOK_SECRET=

# DigiLocker
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# SMS Provider
SMS_PROVIDER_API_KEY=

# WhatsApp
WHATSAPP_API_KEY=

# Application
APP_ENV=dev
RUST_LOG=info
